{
  "name": "qwen-ui-lab",
  "version": "0.4.0",
  "private": true,
  "license": "MIT",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "test": "node --test tests/*.test.mjs",
    "test:e2e": "playwright test",
    "test:e2e:visual": "playwright test e2e/visual-regression.spec.ts",
    "test:e2e:pr-smoke": "playwright test e2e/mobile.spec.ts e2e/a11y.spec.ts e2e/live-qwen-contract.spec.ts",
    "test:e2e:pwa": "playwright test --config=playwright.pwa.config.ts",
    "start:prod:e2e": "node scripts/start-prod-e2e.mjs",
    "doctor": "node scripts/doctor.mjs",
    "validate:assets": "node scripts/validate-public-assets.mjs",
    "deploy:env:demo": "node scripts/validate-deploy-env.mjs --target=demo",
    "deploy:env:live": "node scripts/validate-deploy-env.mjs --target=live",
    "validate:prod": "node scripts/validate-prod-env.mjs --target=production",
    "validate:prod:preview": "node scripts/validate-prod-env.mjs --target=preview",
    "smoke:deploy": "node scripts/post-deploy-smoke.mjs",
    "smoke:live": "node scripts/staged-live-smoke.mjs",
    "smoke:staged": "node scripts/staged-live-smoke.mjs",
    "synthetic:health": "node scripts/synthetic-health-check.mjs",
    "start": "next start",
    "lint": "eslint",
    "check": "npm run lint && npm test",
    "check:full": "npm run check && npm run build",
    "export:demo-fixtures": "node scripts/export-demo-fixtures.mjs",
    "generate:reference-rasters": "node scripts/generate-reference-rasters.mjs",
    "analyze": "node scripts/analyze-build.mjs",
    "perf:lighthouse": "node scripts/perf-lighthouse.mjs",
    "perf:lighthouse:baseline": "node scripts/perf-lighthouse.mjs baseline",
    "perf:lighthouse:after": "node scripts/perf-lighthouse.mjs after",
    "perf:lcp-budget": "node scripts/perf-lcp-budget.mjs"
  },
  "dependencies": {
    "@sentry/browser": "^9.47.0",
    "@base-ui/react": "^1.5.0",
    "chart.js": "^4.5.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "es-toolkit": "^1.39.10",
    "lucide-react": "^1.17.0",
    "next": "16.2.6",
    "next-themes": "^0.4.6",
    "prismjs": "^1.30.0",
    "react": "19.2.4",
    "react-chartjs-2": "^5.3.1",
    "react-dom": "19.2.4",
    "recharts": "^3.8.1",
    "shadcn": "^4.10.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0"
  },
  "overrides": {
    "postcss": "8.5.15",
    "hono": "4.12.26",
    "js-yaml": "4.2.0"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@next/bundle-analyzer": "^16.2.6",
    "@playwright/test": "^1.60.0",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/prismjs": "^1.26.6",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "chrome-launcher": "^1.2.1",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "lighthouse": "^13.3.0",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
