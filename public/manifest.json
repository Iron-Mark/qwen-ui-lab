      "url": "/#upload-flow",
      "icons": [
        {
          "src": "/icons/icon-192.png",
          "sizes": "192x192",
          "type": "image/png"
        }
      ]
    },
    {
      "name": "Design system",
      "short_name": "Patterns",
      "description": "Browse component snippets and UX-law patterns.",
      "url": "/design-system",
      "icons": [
        {
          "src": "/icons/icon-192.png",
          "sizes": "192x192",
          "type": "image/png"
        }
      ]
    },
    {
      "name": "Sample run",
      "short_name": "Sample",
      "description": "Open a guided layout and review a component preview.",
      "url": "/demo",
      "icons": [
        {
          "src": "/icons/icon-192.png",
          "sizes": "192x192",
          "type": "image/png"
        }
      ]
    }
  ],
  "screenshots": [
    {
      "src": "/screenshots/A1-Workflow-Home/desktop-light.png",
      "sizes": "1440x1000",
      "type": "image/png",
      "form_factor": "wide",
      "label": "Workflow home desktop"
    },
    {
      "src": "/screenshots/A2-Upload-Flow/mobile-light.png",
      "sizes": "390x844",
      "type": "image/png",
      "form_factor": "narrow",
      "label": "Upload workflow mobile"
    }
