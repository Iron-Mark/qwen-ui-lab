# Server-only Qwen Model Studio API key.
# Do not prefix with NEXT_PUBLIC_ and do not commit a real value.
# The key alone does NOT call Qwen - see QWEN_LIVE_ANALYSIS below.
DASHSCOPE_API_KEY=

# Opt-in live vision calls (spends API credits). Default: unset / false = local-analysis mode.
# Production lane default is local-analysis safe; enable only for staged live rollout.
# QWEN_LIVE_ANALYSIS=true
# Alias: USE_LIVE_QWEN=1

# Public canonical URL used by metadata, sitemap, robots, PWA links, and
# generated short share URLs. Production should be HTTPS and not localhost.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Required in host env for `npm run deploy:env:live` (app also defaults to qwen3-vl-plus at runtime).
QWEN_MODEL=qwen3-vl-plus

# Optional. Defaults to Singapore Model Studio endpoint.
# Virginia: https://dashscope-us.aliyuncs.com/compatible-mode/v1
# Beijing: https://dashscope.aliyuncs.com/compatible-mode/v1
# Custom MaaS gateways must expose OpenAI-compatible POST /chat/completions.
QWEN_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1

# Optional locally; required for production readiness.
# Default store: in-memory (per serverless instance). Set both KV REST vars for
# durable share links and cluster-wide analyze rate limits in production.
# Live-route rate limiting only runs when QWEN_LIVE_ANALYSIS=true + DASHSCOPE_API_KEY set.
# See docs/ops/LIVE_QWEN_ROLLOUT.md.
# ANALYZE_UI_RATE_LIMIT_MAX=12
# ANALYZE_UI_RATE_LIMIT_WINDOW_MS=60000
# KV_REST_API_URL=
# KV_REST_API_TOKEN=

# Optional client-side observability (OPT-IN - all disabled when unset).
# Public/local-analysis hosts: leave every flag below commented out (safe default).
# Staging activation: see docs/ops/ANALYTICS_STAGING_ACTIVATION.md
# Turn on master switch first, then enable analytics and/or error monitoring.
# Privacy defaults:
# - only allowlisted analytics metadata keys are emitted
# - query strings are stripped from route data
# - local-analysis tracking stays OFF unless explicitly enabled
# NEXT_PUBLIC_OBSERVABILITY_ENABLED=true
# NEXT_PUBLIC_ANALYTICS_ENABLED=true
# NEXT_PUBLIC_ERROR_MONITORING_ENABLED=true
# NEXT_PUBLIC_OBSERVABILITY_ALLOW_LOCAL_ANALYSIS=false
# NEXT_PUBLIC_OBSERVABILITY_DEBUG=false

# Optional error sinks (only used when observability + error monitoring are enabled).
# NEXT_PUBLIC_SENTRY_DSN=
# NEXT_PUBLIC_SENTRY_ENVIRONMENT=staging
# NEXT_PUBLIC_ERROR_REPORTING_URL=

# Optional client-side experimentation flags (all default-off).
# Enable master first, then specific experiments one at a time.
# NEXT_PUBLIC_EXPERIMENTS_ENABLED=true
# NEXT_PUBLIC_EXP_HEADER_DESIGN_SYSTEM_CTA=true
# NEXT_PUBLIC_EXP_UPLOAD_FLOW_HEADLINE=true
# NEXT_PUBLIC_EXP_UPLOAD_FLOW_ANALYZE_CTA=true
# NEXT_PUBLIC_EXP_UPLOAD_FLOW_SAMPLE_PATH_HINT=true

# Optional locally; required for production readiness.
# Server-only GitHub token for one-click "Export to GitHub Gist" and
# "Export to repo" (opens a compare URL with PR instructions).
# Gist: classic PAT with gist scope. Repo compare: repo read is enough to build the compare link.
# Do not commit a real value.
# Production readiness: see docs/ops/PRODUCTION_ENV_READINESS.md and validate with
# node scripts/validate-prod-env.mjs --target=production --env-file=.env.production.local
# GITHUB_TOKEN=
# Optional target repo for compare export (default: Iron-Mark/qwen-ui-lab).
# GITHUB_EXPORT_REPO=owner/repo
# GITHUB_EXPORT_BASE=main

# CSP rollout control. Production defaults to report-only strict policy enabled.
# Set CSP_REPORT_ONLY=false only after report noise has been triaged.
# CSP_REPORT_ONLY=true
